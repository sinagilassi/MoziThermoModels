{
  "name": "mozithermomodels",
  "version": "0.4.0",
  "description": "TypeScript thermodynamic models (EOS + activity)",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Sina Gilassi",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.browser.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "npm run build && node --no-deprecation node_modules/vitest/vitest.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "pack:check": "npm pack --dry-run",
    "pack:make": "npm pack"
  },
  "dependencies": {
    "mozicuc": "^1.1.1",
    "mozithermodb": "^1.3.1",
    "mozithermodb-settings": "^1.1.4"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.13.8",
    "csv-parse": "^6.1.0",
    "eslint": "^10.0.2",
    "rollup": "^4.34.8",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
